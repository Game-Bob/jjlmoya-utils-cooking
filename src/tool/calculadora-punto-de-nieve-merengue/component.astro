---
import "./MeringueCalculator.css";
---

<div class="meringue-calculator-container">
    <div class="meringue-card meringue-fade-in">
        <div class="meringue-input-section">
            <div class="meringue-input-group">
                <label for="whites-input">Peso de las Claras</label>
                <div class="meringue-input-wrapper">
                    <input
                        type="number"
                        id="whites-input"
                        placeholder="Ej. 120"
                        min="1"
                        max="2000"
                        value="120"
                    />
                    <span class="meringue-input-unit">g</span>
                </div>
            </div>

            <div class="meringue-input-group">
                <label>Tipo de Merengue</label>
                <div class="meringue-type-selector" id="type-selector">
                    <button class="meringue-type-btn active" data-type="french">Francés</button>
                    <button class="meringue-type-btn" data-type="italian">Italiano</button>
                    <button class="meringue-type-btn" data-type="swiss">Suizo</button>
                </div>
            </div>
        </div>

        <div class="meringue-results-grid" id="main-results"></div>

        <div class="meringue-time-section">
            <h3
                style="font-size: 1.125rem; font-weight: 800; color: var(--text-dark); margin-bottom: 1.5rem;"
            >
                Tiempos Estimados (Batido a media/alta velocidad)
            </h3>
            <div class="meringue-time-grid" id="time-grid"></div>
        </div>

        <div class="meringue-pro-tip" id="pro-tip">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <p id="tip-text">
                El merengue francés es el más común y fácil, ideal para hornear suspiros.
            </p>
        </div>
    </div>
</div>

<script>
    const whitesInput = document.getElementById("whites-input");
    const typeSelector = document.getElementById("type-selector");
    const resultsGrid = document.getElementById("main-results");
    const timeGrid = document.getElementById("time-grid");
    const tipText = document.getElementById("tip-text");

    let currentType = "french";

    const TIPS = {
        french: "El merengue francés es el más común y fácil, ideal para hornear suspiros o añadir a masas aireadas. No es apto para comer en crudo.",
        italian: "El merengue italiano es el más estable. Se hace con almíbar caliente a 118°C. Es perfecto para decorar tartas y comer directamente.",
        swiss: "El merengue suizo se calienta al baño maría hasta que el azúcar se disuelve. Es muy versátil y ideal para cremas de mantequilla.",
    };

    const STAGES = [
        { name: "Espumado", desc: "Burbujas grandes, como jabón.", timeIdx: 0 },
        { name: "Pico Blando", desc: "La punta se dobla al levantar.", timeIdx: 1 },
        { name: "Punto de Nieve", desc: "Pico firme y brillante.", timeIdx: 2 },
    ];

    function getRecipeData(type, weight) {
        const recipes = {
            french: {
                results: [
                    { label: "Azúcar Blanquilla", val: weight, unit: "g" },
                    { label: "Azúcar Glas", val: weight, unit: "g" },
                ],
                times: ["1-2 min", "3-5 min", "7-9 min"],
            },
            italian: {
                results: [
                    { label: "Azúcar para Almíbar", val: weight * 2, unit: "g" },
                    { label: "Agua", val: Math.round(weight * 0.6), unit: "ml" },
                ],
                times: ["2 min", "5 min", "10-12 min"],
            },
            swiss: {
                results: [
                    { label: "Azúcar Blanquilla", val: weight * 2, unit: "g" },
                    { label: "Temperatura Máx", val: 60, unit: "°C" },
                ],
                times: ["1-2 min", "4-6 min", "8-10 min"],
            },
        };
        return recipes[type];
    }

    function renderResults(mainResults) {
        resultsGrid.innerHTML = "";
        mainResults.forEach((res) => {
            const item = document.createElement("div");
            item.className = "meringue-result-item meringue-fade-in";
            item.innerHTML = `
                <span class="meringue-result-label">${res.label}</span>
                <span class="meringue-result-value">${res.val}<span class="meringue-result-unit">${res.unit}</span></span>
            `;
            resultsGrid.appendChild(item);
        });
    }

    function renderStages(times) {
        timeGrid.innerHTML = "";
        STAGES.forEach((stage, i) => {
            const row = document.createElement("div");
            row.className = "meringue-time-row meringue-fade-in";
            row.style.animationDelay = `${i * 0.1}s`;
            row.innerHTML = `
                <div class="meringue-time-info">
                    <span class="meringue-time-stage">${stage.name}</span>
                    <span class="meringue-time-desc">${stage.desc}</span>
                </div>
                <span class="meringue-time-val">${times[i]}</span>
            `;
            timeGrid.appendChild(row);
        });
    }

    function calculate() {
        const weight = parseFloat(whitesInput.value) || 0;

        if (weight <= 0) {
            resultsGrid.innerHTML = '<p style="color: #ef4444; font-weight: 600;">Introduce un peso válido</p>';
            return;
        }

        const recipe = getRecipeData(currentType, weight);
        renderResults(recipe.results);
        renderStages(recipe.times);
        tipText.textContent = TIPS[currentType];
    }

    whitesInput?.addEventListener("input", calculate);

    typeSelector?.addEventListener("click", (e) => {
        const target = e.target;
        if (target.classList.contains("meringue-type-btn")) {
            const btns = typeSelector.querySelectorAll(".meringue-type-btn");
            btns.forEach((b) => b.classList.remove("active"));
            target.classList.add("active");
            currentType = target.dataset.type || "french";
            calculate();
        }
    });

    calculate();
</script>
