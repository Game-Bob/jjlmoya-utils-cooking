---
import { Icon } from "astro-icon/components";
import "./KitchenTimer.css";

interface Props {
  ui: Record<string, string>;
}

const { ui } = Astro.props;
---

<div class="kitchen-timer-wrapper">
	<div id="timers-grid" class="timers-grid">
		<div class="timer-card" data-index="0">
			<div class="progress-bar">
				<div class="progress-fill"></div>
			</div>

			<div class="timer-content">
				<div class="timer-header">
					<div class="timer-name-wrapper">
						<input
							type="text"
							value={ui.timerDefault1}
							class="timer-name"
							placeholder={ui.label}
						/>
					</div>
					<div class="status-badge">
						<span class="status-text">{ui.ready}</span>
					</div>
				</div>

				<div class="timer-display">
					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="99"
								value="00"
								class="time-input hours"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.hours}</label>
					</div>

					<span class="time-separator">:</span>

					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="59"
								value="00"
								class="time-input minutes"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.minutes}</label>
					</div>

					<span class="time-separator">:</span>

					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="59"
								value="00"
								class="time-input seconds"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.seconds}</label>
					</div>
				</div>

				<div class="timer-controls">
					<div class="timer-buttons">
						<button class="btn-toggle" disabled>
							<span class="icon-play">
								<Icon name="mdi:play" />
							</span>
							<span class="icon-pause" style="display: none;">
								<Icon name="mdi:pause" />
							</span>
							<span class="btn-text">{ui.start}</span>
						</button>

						<button class="btn-reset">
							<Icon name="mdi:refresh" />
							{ui.reset}
						</button>
					</div>

					<div class="timer-quick-buttons">
						<button class="btn-add-1m">{ui.addOneMin}</button>
						<button class="btn-add-5m">{ui.addFiveMin}</button>
					</div>
				</div>
			</div>
		</div>

		<div class="timer-card" data-index="1">
			<div class="progress-bar">
				<div class="progress-fill"></div>
			</div>

			<div class="timer-content">
				<div class="timer-header">
					<div class="timer-name-wrapper">
						<input
							type="text"
							value={ui.timerDefault2}
							class="timer-name"
							placeholder={ui.label}
						/>
					</div>
					<div class="status-badge">
						<span class="status-text">{ui.ready}</span>
					</div>
				</div>

				<div class="timer-display">
					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="99"
								value="00"
								class="time-input hours"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.hours}</label>
					</div>

					<span class="time-separator">:</span>

					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="59"
								value="00"
								class="time-input minutes"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.minutes}</label>
					</div>

					<span class="time-separator">:</span>

					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="59"
								value="00"
								class="time-input seconds"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.seconds}</label>
					</div>
				</div>

				<div class="timer-controls">
					<div class="timer-buttons">
						<button class="btn-toggle" disabled>
							<span class="icon-play">
								<Icon name="mdi:play" />
							</span>
							<span class="icon-pause" style="display: none;">
								<Icon name="mdi:pause" />
							</span>
							<span class="btn-text">{ui.start}</span>
						</button>

						<button class="btn-reset">
							<Icon name="mdi:refresh" />
							{ui.reset}
						</button>
					</div>

					<div class="timer-quick-buttons">
						<button class="btn-add-1m">{ui.addOneMin}</button>
						<button class="btn-add-5m">{ui.addFiveMin}</button>
					</div>
				</div>
			</div>
		</div>

		<div class="timer-card" data-index="2">
			<div class="progress-bar">
				<div class="progress-fill"></div>
			</div>

			<div class="timer-content">
				<div class="timer-header">
					<div class="timer-name-wrapper">
						<input
							type="text"
							value={ui.timerDefault3}
							class="timer-name"
							placeholder={ui.label}
						/>
					</div>
					<div class="status-badge">
						<span class="status-text">{ui.ready}</span>
					</div>
				</div>

				<div class="timer-display">
					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="99"
								value="00"
								class="time-input hours"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.hours}</label>
					</div>

					<span class="time-separator">:</span>

					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="59"
								value="00"
								class="time-input minutes"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.minutes}</label>
					</div>

					<span class="time-separator">:</span>

					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="59"
								value="00"
								class="time-input seconds"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.seconds}</label>
					</div>
				</div>

				<div class="timer-controls">
					<div class="timer-buttons">
						<button class="btn-toggle" disabled>
							<span class="icon-play">
								<Icon name="mdi:play" />
							</span>
							<span class="icon-pause" style="display: none;">
								<Icon name="mdi:pause" />
							</span>
							<span class="btn-text">{ui.start}</span>
						</button>

						<button class="btn-reset">
							<Icon name="mdi:refresh" />
							{ui.reset}
						</button>
					</div>

					<div class="timer-quick-buttons">
						<button class="btn-add-1m">{ui.addOneMin}</button>
						<button class="btn-add-5m">{ui.addFiveMin}</button>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="add-timer-container">
		<button id="add-timer-btn" class="add-timer-btn">
			<div class="add-timer-icon">
				<Icon name="mdi:plus" />
			</div>
			<span>{ui.addTimer}</span>
		</button>
	</div>

	<div class="stop-all-container">
		<button id="stop-all" class="stop-all-btn">
			<Icon name="mdi:stop-circle-outline" />
			{ui.stopAll}
		</button>
	</div>

	<template id="timer-template">
		<div class="timer-card" data-index="-1">
			<div class="progress-bar">
				<div class="progress-fill"></div>
			</div>

			<div class="timer-content">
				<div class="timer-header">
					<div class="timer-name-wrapper">
						<input
							type="text"
							value={ui.newTimerName}
							class="timer-name"
							placeholder={ui.label}
						/>
					</div>
					<div class="status-badge">
						<span class="status-text">{ui.ready}</span>
					</div>
				</div>

				<div class="timer-display">
					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="99"
								value="00"
								class="time-input hours"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.hours}</label>
					</div>

					<span class="time-separator">:</span>

					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="59"
								value="00"
								class="time-input minutes"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.minutes}</label>
					</div>

					<span class="time-separator">:</span>

					<div class="time-input-group">
						<div class="time-input-box">
							<input
								type="number"
								min="0"
								max="59"
								value="00"
								class="time-input seconds"
								placeholder="00"
							/>
						</div>
						<label class="time-label">{ui.seconds}</label>
					</div>
				</div>

				<div class="timer-controls">
					<div class="timer-buttons">
						<button class="btn-toggle" disabled>
							<span class="icon-play">
								<Icon name="mdi:play" />
							</span>
							<span class="icon-pause" style="display: none;">
								<Icon name="mdi:pause" />
							</span>
							<span class="btn-text">{ui.start}</span>
						</button>

						<button class="btn-reset">
							<Icon name="mdi:refresh" />
							{ui.reset}
						</button>
					</div>

					<div class="timer-quick-buttons">
						<button class="btn-add-1m">{ui.addOneMin}</button>
						<button class="btn-add-5m">{ui.addFiveMin}</button>
					</div>
				</div>
			</div>
		</div>
	</template>

	<div id="mobile-dock" class="mobile-dock" data-visible="false">
		<div id="mobile-dock-container" class="mobile-dock-container"></div>
	</div>
</div>

<script>
	import { initKitchenTimers } from "./init";

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initKitchenTimers);
	} else {
		initKitchenTimers();
	}
</script>
