---
import { Icon } from 'astro-icon/components';

interface Props {
	ui: Record<string, string>;
}

const { ui } = Astro.props;
const placeholderText = `${ui.pasteHere}
${ui.exampleLine1}
${ui.exampleLine2}
${ui.exampleLine3}
${ui.exampleLine4}`;
---

<div class="ingredient-rescaler-container">
	<div class="ir-grid" id="calculator-interface">
		<div>
			<section class="ir-section ir-section-primary">
				<h3 class="ir-section-title">
					<span>1.</span> {ui.servings}
				</h3>

				<div class="ir-fields">
					<div class="ir-field">
						<label for="original-servings" class="ir-label">{ui.original}</label>
						<input
							type="number"
							id="original-servings"
							value="4"
							min="1"
							class="ir-input"
						/>
					</div>
					<div class="ir-field">
						<label for="target-servings" class="ir-label">{ui.desired}</label>
						<input
							type="number"
							id="target-servings"
							value="7"
							min="1"
							class="ir-input"
						/>
					</div>
				</div>

				<div class="ir-factor-display">
					<span class="ir-factor-label">{ui.multiplyingFactor}</span>
					<span id="multiplier-display" class="ir-factor-value">1.75x</span>
				</div>
			</section>
		</div>

		<div class="ir-textarea-container">
			<section class="ir-section">
				<h3 class="ir-section-title">
					<span>2.</span> {ui.ingredientsList}
				</h3>

				<textarea
					id="ingredients-input"
					placeholder={placeholderText}
					class="ir-textarea"
					spellcheck="false"
				></textarea>
			</section>
		</div>
	</div>

	<div class="ir-results-card">
		<div class="ir-results-header">
			<h3 class="ir-results-title">
				<Icon name="mdi:chef-hat" /> {ui.result}
			</h3>
			<button id="copy-btn" class="ir-copy-btn ir-default">
				<Icon name="mdi:content-copy" /> {ui.copy}
			</button>
		</div>

		<div id="results-container" class="ir-results-container">
			<div class="ir-empty-state">
				<Icon name="mdi:pot-steam" class="ir-empty-icon" />
				<p>{ui.emptyState}</p>
			</div>
		</div>
	</div>
</div>

<script>
	import { initIngredientRescaler } from './init';
	window.__initIngredientRescaler = initIngredientRescaler;
</script>

<script define:vars={{ ui }}>
	const init = () => {
		if (window.__initIngredientRescaler) {
			window.__initIngredientRescaler(ui);
		}
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>


<style>
	.ingredient-rescaler-container {
		max-width: 100%;
		padding: 1.5rem;
		background: var(--ir-bg-card);
		border: 1px solid var(--ir-border);
		border-radius: var(--ir-radius);
		box-shadow: var(--ir-shadow-lg);
	}

	.ir-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	@media (min-width: 768px) {
		.ir-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	.ir-section {
		background: var(--ir-bg-app);
		padding: 1.5rem;
		border-radius: 1.25rem;
		border: 1px solid var(--ir-border);
	}

	.ir-section-primary {
		background: var(--ir-bg-card);
		border: 2px solid var(--ir-primary);
	}

	.ir-section-title {
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--ir-text-main);
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.ir-section-primary .ir-section-title {
		color: var(--ir-primary);
	}

	.ir-fields {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.ir-field {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.ir-label {
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--ir-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.ir-input {
		width: 100%;
		padding: 0.75rem 1rem;
		border-radius: 0.75rem;
		border: 1px solid var(--ir-border);
		background: var(--ir-bg-card);
		color: var(--ir-text-main);
		font-weight: 600;
		font-size: 1.125rem;
		text-align: center;
		transition: all 0.3s ease;
	}

	.ir-input:focus {
		outline: none;
		border-color: var(--ir-primary);
		box-shadow: 0 0 0 3px hsl(220deg, 90%, 56%, 0.1);
	}

	.ir-factor-display {
		margin-top: 1rem;
		padding: 1rem;
		background: var(--ir-primary-light);
		border-radius: 0.75rem;
		border: 1px solid var(--ir-primary);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.ir-factor-label {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--ir-text-muted);
	}

	.ir-factor-value {
		font-size: 2rem;
		font-weight: 800;
		color: var(--ir-primary);
	}

	.ir-textarea-container {
		display: flex;
		flex-direction: column;
		height: 100%;
		gap: 0.5rem;
	}

	.ir-textarea {
		width: 100%;
		flex: 1;
		min-height: 200px;
		padding: 1rem;
		border-radius: 0.75rem;
		border: 1px solid var(--ir-border);
		background: var(--ir-bg-card);
		color: var(--ir-text-main);
		font-size: 0.875rem;
		resize: none;
		line-height: 1.6;
		transition: all 0.3s ease;
	}

	.ir-textarea:focus {
		outline: none;
		border-color: var(--ir-primary);
		box-shadow: 0 0 0 3px hsl(220deg, 90%, 56%, 0.1);
	}

	.ir-textarea::placeholder {
		color: hsl(210deg, 15%, 75%);
	}

	.ir-results-card {
		background: var(--ir-text-main);
		border-radius: 1.25rem;
		border: 1px solid var(--ir-border);
		overflow: hidden;
		box-shadow: var(--ir-shadow-lg);
	}

	.ir-results-header {
		padding: 1rem 1.5rem;
		background: hsl(210deg, 30%, 15%);
		border-bottom: 1px solid hsl(210deg, 30%, 25%);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	:global(.theme-dark) .ir-results-header {
		background: hsl(220deg, 25%, 8%);
		border-bottom-color: hsl(220deg, 25%, 20%);
	}

	.ir-results-title {
		color: var(--ir-bg-card);
		font-weight: 700;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	:global(.theme-dark) .ir-results-title {
		color: var(--ir-text-main);
	}

	.ir-copy-btn {
		font-size: 0.75rem;
		background: hsl(210deg, 30%, 35%);
		color: var(--ir-bg-card);
		padding: 0.5rem 1rem;
		border-radius: 0.5rem;
		border: none;
		cursor: pointer;
		transition: all 0.3s ease;
		font-weight: 600;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	:global(.theme-dark) .ir-copy-btn {
		background: hsl(220deg, 25%, 30%);
		color: var(--ir-text-main);
	}

	.ir-copy-btn:hover {
		background: hsl(210deg, 30%, 45%);
	}

	:global(.theme-dark) .ir-copy-btn:hover {
		background: hsl(220deg, 25%, 40%);
	}

	.ir-copy-btn.ir-copied {
		background: hsl(142deg, 72%, 45%);
	}

	.ir-results-container {
		padding: 2rem;
		font-size: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-height: 200px;
		background: var(--ir-bg-card);
		color: var(--ir-text-main);
	}

	.ir-empty-state {
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		opacity: 0.5;
		color: var(--ir-text-muted);
	}

	.ir-empty-icon {
		width: 3rem;
		height: 3rem;
	}

	:global(.ir-result-row) {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: var(--ir-bg-app);
		padding: 0.75rem;
		border-radius: 0.5rem;
		border-left: 4px solid transparent;
		transition: all 0.3s ease;
	}

	:global(.ir-result-row):hover {
		background: var(--ir-primary-light);
		border-left-color: var(--ir-primary);
	}

	.ir-original-amount {
		color: hsl(210deg, 15%, 75%);
		font-size: 0.75rem;
		text-decoration: line-through;
		opacity: 0.75;
	}

	.ir-new-value {
		color: var(--ir-primary);
		font-weight: 800;
		font-size: 1.125rem;
	}

	:global(.ir-no-amount-row) {
		color: var(--ir-text-muted);
		font-style: italic;
		font-size: 0.875rem;
		padding: 0.5rem;
		background: transparent;
	}
</style>
