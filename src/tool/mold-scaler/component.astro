---

interface Props {
	ui: Record<string, string>;
}

const { ui } = Astro.props;
---

<div class="mold-scaler-container">
	<div class="ms-card">
		<aside class="ms-sidebar">
			<section class="ms-section">
				<h2 class="ms-section-title">
					<span class="ms-section-badge">1</span>
					{ui.originalRecipe}
				</h2>

				<div class="ms-shape-selector">
					<button class="ms-shape-btn active" data-target="original" data-shape="round" title={ui.round}>
						<div class="ms-shape-icon"></div>
						<span>{ui.round}</span>
					</button>
					<button class="ms-shape-btn" data-target="original" data-shape="square" title={ui.square}>
						<div class="ms-shape-icon"></div>
						<span>{ui.square}</span>
					</button>
					<button class="ms-shape-btn" data-target="original" data-shape="rectangular" title={ui.rectangular}>
						<div class="ms-shape-icon"></div>
						<span>{ui.rectangular}</span>
					</button>
				</div>

				<div id="original-inputs" class="ms-inputs-container"></div>
			</section>

			<section class="ms-section">
				<h2 class="ms-section-title">
					<span class="ms-section-badge">2</span>
					{ui.yourMold}
				</h2>

				<div class="ms-shape-selector">
					<button class="ms-shape-btn active" data-target="target" data-shape="round" title={ui.round}>
						<div class="ms-shape-icon"></div>
						<span>{ui.round}</span>
					</button>
					<button class="ms-shape-btn" data-target="target" data-shape="square" title={ui.square}>
						<div class="ms-shape-icon"></div>
						<span>{ui.square}</span>
					</button>
					<button class="ms-shape-btn" data-target="target" data-shape="rectangular" title={ui.rectangular}>
						<div class="ms-shape-icon"></div>
						<span>{ui.rectangular}</span>
					</button>
				</div>

				<div id="target-inputs" class="ms-inputs-container"></div>
			</section>

			<div class="ms-viz-container">
				<svg id="visualizer" class="ms-viz-svg" viewBox="0 0 400 300">
					<g transform="translate(200, 150)">
						<path id="shape-original" fill="hsla(262, 83%, 58%, 0.15)" stroke="var(--ms-primary)" stroke-width="2" stroke-dasharray="4 4" />
						<path id="shape-target" fill="hsla(150, 80%, 40%, 0.15)" stroke="var(--ms-success)" stroke-width="2" />
					</g>
				</svg>
				<div class="ms-viz-legend">
					<div class="ms-legend-item">
						<span class="ms-dot original"></span>
						<span>{ui.originalVisualization}</span>
					</div>
					<div class="ms-legend-item">
						<span class="ms-dot target"></span>
						<span>{ui.yourVisualization}</span>
					</div>
				</div>
			</div>
		</aside>

		<main class="ms-main">
			<div class="ms-hero-result">
				<div class="ms-result-label">{ui.multiplyingFactor}</div>
				<div class="ms-result-value" id="result-factor">x1.00</div>
				<div class="ms-result-text" id="result-text">{ui.equivalentMolds}</div>
			</div>

			<section class="ms-ingredients-section">
				<h3 class="ms-section-title">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H20a2 2 0 0 1 2 2v5"/><path d="M16 19h6"/><path d="M19 16v6"/><circle cx="8" cy="12" r="2"/><circle cx="15" cy="12" r="2"/></svg>
					{ui.ingredientCalculator}
				</h3>

				<div class="ms-ingredients-card">
					<div id="ingredients-list" class="ms-ingredients-list"></div>

					<button id="add-ingredient-btn" class="ms-add-btn">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
						{ui.addIngredient}
					</button>
				</div>
			</section>
		</main>
	</div>
</div>

<script>
	import { initMoldScaler } from './init';
	window.__initMoldScaler = initMoldScaler;
</script>

<script define:vars={{ ui }}>
	const init = () => {
		if (window.__initMoldScaler) {
			window.__initMoldScaler(ui);
		}
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>

<style>
	:root {
		--ms-primary: hsl(262deg, 83%, 58%);
		--ms-primary-light: hsl(262deg, 83%, 95%);
		--ms-primary-dark: hsl(262deg, 83%, 45%);
		--ms-bg-card: hsl(0deg, 0%, 100%);
		--ms-bg-app: hsl(210deg, 20%, 98%);
		--ms-border: hsl(210deg, 20%, 90%);
		--ms-text-main: hsl(210deg, 30%, 20%);
		--ms-text-muted: hsl(210deg, 15%, 50%);
		--ms-shadow-lg: 0 10px 15px -3px rgb(0, 0, 0, 0.1);
		--ms-radius: 1rem;
		--ms-transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	:global(.theme-dark) {
		--ms-bg-card: hsl(220deg, 25%, 12%);
		--ms-bg-app: hsl(220deg, 30%, 7%);
		--ms-border: hsl(220deg, 20%, 20%);
		--ms-text-main: hsl(210deg, 20%, 95%);
		--ms-text-muted: hsl(210deg, 15%, 70%);
		--ms-primary-light: hsl(262deg, 83%, 15%);
	}

	.mold-scaler-container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 1rem;
	}

	.ms-card {
		background: var(--ms-bg-card);
		border: 1px solid var(--ms-border);
		border-radius: var(--ms-radius);
		box-shadow: var(--ms-shadow-lg);
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	@media (min-width: 1024px) {
		.ms-card {
			flex-direction: row;
			min-height: 700px;
		}
	}

	.ms-sidebar {
		flex: 1;
		padding: 2rem;
		border-bottom: 1px solid var(--ms-border);
		background: linear-gradient(to bottom, var(--ms-bg-card), var(--ms-primary-light));
	}

	@media (min-width: 1024px) {
		.ms-sidebar {
			border-bottom: none;
			border-right: 1px solid var(--ms-border);
			max-width: 450px;
		}
	}

	.ms-main {
		flex: 1.5;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.ms-section {
		margin-bottom: 2rem;
	}

	.ms-section-title {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--ms-text-main);
		margin-bottom: 1.5rem;
	}

	.ms-section-badge {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		background: var(--ms-primary);
		color: var(--ms-bg-card);
		border-radius: 50%;
		font-size: 0.875rem;
	}

	.ms-shape-selector {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem;
		margin-bottom: 1.25rem;
	}

	.ms-shape-btn {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 0.75rem;
		border-radius: 0.75rem;
		border: 1px solid var(--ms-border);
		background: var(--ms-bg-card);
		color: var(--ms-text-muted);
		cursor: pointer;
		transition: var(--ms-transition);
		font-size: 0.875rem;
		font-weight: 600;
	}

	.ms-shape-btn:hover {
		border-color: var(--ms-primary);
		color: var(--ms-primary);
	}

	.ms-shape-btn.active {
		background: var(--ms-primary);
		color: var(--ms-bg-card);
		border-color: var(--ms-primary);
		box-shadow: 0 4px 12px hsla(262deg, 83%, 58%, 0.3);
	}

	.ms-shape-icon {
		width: 2rem;
		height: 2rem;
		margin-bottom: 0.5rem;
		border: 2px solid currentcolor;
		transition: var(--ms-transition);
	}

	.ms-shape-btn[data-shape="round"] .ms-shape-icon {
		border-radius: 50%;
	}

	.ms-shape-btn[data-shape="square"] .ms-shape-icon {
		border-radius: 4px;
	}

	.ms-shape-btn[data-shape="rectangular"] .ms-shape-icon {
		border-radius: 2px;
		width: 2.5rem;
	}

	:global(.ms-input-group) {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	:global(.ms-label) {
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--ms-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	:global(.ms-input) {
		width: 100%;
		padding: 0.75rem 1rem;
		border-radius: 0.5rem;
		border: 1px solid var(--ms-border);
		background: var(--ms-bg-card);
		color: var(--ms-text-main);
		font-weight: 600;
		transition: var(--ms-transition);
	}

	:global(.ms-input):focus {
		outline: none;
		border-color: var(--ms-primary);
		box-shadow: 0 0 0 3px hsla(262deg, 83%, 58%, 0.1);
	}

	.ms-hero-result {
		text-align: center;
		padding: 2.5rem;
		background: linear-gradient(135deg, var(--ms-primary), var(--ms-primary-dark));
		color: hsl(0deg, 0%, 100%);
		border-radius: var(--ms-radius);
		box-shadow: var(--ms-shadow-md);
		position: relative;
		overflow: hidden;
	}

	.ms-result-label {
		font-size: 0.875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 0.8;
		margin-bottom: 0.5rem;
	}

	.ms-result-value {
		font-size: 4rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
		line-height: 1;
	}

	.ms-result-text {
		font-size: 1rem;
		opacity: 0.9;
		max-width: 300px;
		margin: 0 auto;
	}

	.ms-viz-container {
		background: var(--ms-bg-app);
		border: 1px solid var(--ms-border);
		border-radius: var(--ms-radius);
		padding: 1.5rem;
		position: relative;
		aspect-ratio: 4 / 3;
		display: flex;
		flex-direction: column;
	}

	.ms-viz-svg {
		flex: 1;
		width: 100%;
		height: 100%;
	}

	.ms-viz-legend {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		padding-top: 1rem;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.ms-legend-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.ms-dot {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
	}

	.ms-dot.original {
		background: var(--ms-primary);
		opacity: 0.5;
		border: 1px dashed var(--ms-primary);
	}

	.ms-dot.target {
		background: hsl(150deg, 80%, 40%);
		opacity: 0.8;
		border: 1px solid hsl(150deg, 80%, 40%);
	}

	.ms-ingredients-card {
		border: 1px solid var(--ms-border);
		border-radius: var(--ms-radius);
		padding: 1.5rem;
	}

	.ms-ingredients-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	:global(.ms-ingredient-row) {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
		padding: 1rem;
		background: var(--ms-bg-app);
		border-radius: 0.75rem;
		border: 1px solid var(--ms-border);
		position: relative;
		animation: slide-in 0.3s ease-out;
	}

	@keyframes slide-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (min-width: 640px) {
		:global(.ms-ingredient-row) {
			grid-template-columns: 2fr 1fr 1fr auto;
			align-items: center;
		}
	}

	:global(.ms-ingredient-final) {
		font-weight: 800;
		color: hsl(150deg, 80%, 40%);
		font-size: 1.125rem;
		padding: 0.5rem;
		text-align: center;
	}

	:global(.ms-del-btn) {
		background: transparent;
		border: none;
		color: var(--ms-text-muted);
		cursor: pointer;
		padding: 0.5rem;
		border-radius: 0.5rem;
		transition: var(--ms-transition);
	}

	:global(.ms-del-btn):hover {
		background: hsl(0deg, 85%, 60%);
		color: var(--ms-bg-card);
	}

	.ms-add-btn {
		width: 100%;
		padding: 1rem;
		background: transparent;
		border: 2px dashed var(--ms-primary);
		color: var(--ms-primary);
		border-radius: 0.75rem;
		font-weight: 700;
		cursor: pointer;
		transition: var(--ms-transition);
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.ms-add-btn:hover {
		background: var(--ms-primary-light);
		border-style: solid;
	}

	:global(.ms-empty-state) {
		text-align: center;
		padding: 2rem;
		color: var(--ms-text-muted);
		font-style: italic;
	}

	:global(.ms-inputs-grid) {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}
</style>

